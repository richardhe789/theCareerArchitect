{
  "builds": [
    {
      "src": "nextjs-app/package.json",
      "use": "@vercel/next"
    },
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    { "src": "/api/jobs", "dest": "/api/index.py" },
    { "src": "/api/scrape", "dest": "/api/index.py" },
    { "src": "/api/health", "dest": "/api/index.py" },
    { "src": "/api/(.*)", "dest": "/api/index.py" },
    { "src": "/(.*)", "dest": "nextjs-app/$1" }
  ]
}